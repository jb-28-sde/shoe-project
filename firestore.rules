rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'manjubangre24@gmail.com'; 
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'description', 'category', 'color', 'createdAt']) && 
             data.keys().size() == 7 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category is string && data.category.size() <= 50 &&
             data.color is string && data.color.size() <= 50 &&
             data.createdAt is timestamp;
    }

    function isValidProductUpdate(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'description', 'category', 'color']) && 
             data.keys().size() == 7 && // includes createdAt
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() <= 1000 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category is string && data.category.size() <= 50 &&
             data.color is string && data.color.size() <= 50;
    }


    match /products/{productId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidProductUpdate(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'total', 'status', 'items', 'createdAt', 'customerName', 'customerEmail']) &&
             data.keys().size() == 7 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.total is number && data.total >= 0 &&
             data.status is string && data.status.size() <= 20 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.createdAt is timestamp &&
             data.customerName is string && data.customerName.size() <= 100 &&
             data.customerEmail is string && data.customerEmail.size() <= 100;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow create: if isValidOrder(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin(); // Admins can update order status
      allow delete: if isAdmin();
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'text', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.productId is string && data.productId.size() > 0 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.text is string && data.text.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming()) && incoming().createdAt == request.time;
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
